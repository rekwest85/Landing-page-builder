# Neon Postgres — get the connection string from neon.tech
# Pooled URL for serverless/edge:
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/forge?sslmode=require"

# Direct (non-pooled) URL for migrations:
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/forge?sslmode=require"

# OpenAI / Anthropic / DeepSeek / etc. — fill in whichever you want for AI generation
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
DEEPSEEK_API_KEY=""

# The root domain for published pages. Subdomains resolve to user pages.
# Local dev: localhost
# Production: forge.so (or whatever you register)
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
